      "launchBrowser": true,
      "applicationUrl": "https://ganihuhstack.dev.localhost:17046;http://ganihuhstack.dev.localhost:15264",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",
        "DOTNET_DASHBOARD_OTLP_ENDPOINT_URL": "https://localhost:21111",
